#include <stdio.h>

int disp_single digit_Prime(int n)
{
    int digit, count = 0;

    while(n > 0)
    {
        digit = n % 10;

        if(digit == 2 || digit == 3 || digit == 5 || digit == 7)
            count++;

        n = n / 10;
    }

    return count;
}

