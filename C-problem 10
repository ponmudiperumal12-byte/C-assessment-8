#include <stdio.h>

int disp_single_prime_number()
{
    int i, count = 0;

    for(i = 2; i <= 9; i++)
    {
        if(i == 2 || i == 3 || i == 5 || i == 7)
            count++;
    }

    return count;
}

int main()
{
    int ans;

    ans = disp_single_prime_number();

    printf("%d", ans);

}
