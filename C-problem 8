#include <stdio.h>

int disp_interchange_first_last_digit(int n)
{
    int first, last, temp, div = 1, middle;

    last = n % 10;

    temp = n;
    while(temp >= 10)
    {
        temp = temp / 10;
        div = div * 10;
    }

    first = temp;
    middle = (n % div) / 10;

    return last * div + middle * 10 + first;
}

int main()
{
    int n, ans;

    scanf("%d", &n);

    ans = disp_interchange_first_last_digit(n);

    printf("%d", ans);

}
